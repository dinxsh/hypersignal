# Single Vercel project: one @vercel/python function (api/index.py) whose
# FastAPI app serves the built dashboard at / and the API at /report.
# Everything not excluded here is bundled (includeFiles "**" in vercel.json),
# so keep dashboard/dist and src/ — but drop everything not needed at runtime.
.venv/
_live/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
.github/
tests/
scripts/
dashboard/node_modules/
dashboard/src/
dashboard/public/
dashboard/*.config.*
dashboard/tsconfig*.json
dashboard/package*.json
