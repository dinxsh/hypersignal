# NOTE: Vercel applies this repo-root .vercelignore to the WHOLE clone, even
# for a project whose Root Directory is "dashboard". So it must NOT remove the
# dashboard's source (package.json / src), or `npm install` there fails.
# We only drop things no deploy needs.
.venv/
_live/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
.github/
tests/
scripts/
node_modules/
dashboard/node_modules/
