# SIMPLEST live deploy: set this and deploy the dashboard as a static site.
# The dashboard calls GoldRush directly from the browser (CORS is open), so it
# needs no backend. NOTE: this key ships in the built JS bundle — use a
# rotatable / usage-capped key for public deploys.
VITE_GOLDRUSH_API_KEY=cqt_your_key_here

# Alternative: point at a hypersignal backend instead (key stays server-side).
# If VITE_GOLDRUSH_API_KEY is set, it takes precedence over this.
# VITE_API_URL=https://your-hypersignal-api.example.com
