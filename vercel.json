{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {
      "src": "dashboard/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/report.py",
      "use": "@vercel/python",
      "config": { "includeFiles": "src/**" }
    }
  ],
  "routes": [
    { "src": "/api/report", "dest": "/api/report.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
